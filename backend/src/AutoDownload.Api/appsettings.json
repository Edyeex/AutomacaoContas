{
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001"
    ]
  },
  "Security": {
    "AccessToken": {
      "Issuer": "AutoDownload",
      "Audience": "AutoDownload.Frontend",
      "ExpirationMinutes": 120
    }
  },
  "Automation": {
    "EnableScheduler": false,
    "VeroInternet": {
      "LoginUrl": "https://verointernet.com.br/minhavero/login",
      "InvoiceUrl": "https://verointernet.com.br/minhavero/fatura",
      "DownloadDirectory": "%USERPROFILE%\\Downloads",
      "Headless": false,
      "TimeoutSeconds": 30,
      "DownloadTimeoutSeconds": 60
    },
    "RmsTelecom": {
      "LoginUrl": "https://fatura.rmstelecom.net/login",
      "PortalUrl": "https://fatura.rmstelecom.net/",
      "InvoicesUrl": "https://fatura.rmstelecom.net/",
      "ApiBaseUrl": "https://api.portal.cs30.7az.com.br/",
      "DownloadDirectory": "%USERPROFILE%\\Downloads",
      "Headless": false,
      "TimeoutSeconds": 30,
      "DownloadTimeoutSeconds": 60,
      "PaymentWindowDays": 31
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
